{
  "name": "ai-autonomous-notary",
  "version": "1.0.0",
  "description": "AI Autonomous Notary - Document Securities Market Protocol",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:compliance": "hardhat test test/compliance-overlay/*.js",
    "test:coverage": "hardhat coverage",
    "test:gas": "REPORT_GAS=true hardhat test",
    "node": "hardhat node",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
    "deploy:polygon": "hardhat run scripts/deploy.js --network polygon",
    "deploy:mainnet": "hardhat run scripts/deploy.js --network mainnet",
    "verify": "hardhat verify",
    "lint": "solhint 'contracts/**/*.sol'",
    "lint:fix": "solhint 'contracts/**/*.sol' --fix",
    "format": "prettier --write 'contracts/**/*.sol' 'test/**/*.js' 'scripts/**/*.js'",
    "size": "hardhat size-contracts",
    "slither": "slither .",
    "clean": "hardhat clean",
    "compliance:flow": "node scripts/compliance/run-compliant-flow.js",
    "compliance:validate": "node scripts/compliance/validate-policies.js",
    "compliance:shadow": "node scripts/compliance/run-shadow-benchmark.js"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.6"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "chai": "^4.5.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.16.0",
    "hardhat": "^2.22.2",
    "hardhat-contract-sizer": "^2.10.0",
    "hardhat-gas-reporter": "^1.0.10",
    "prettier": "^3.2.5",
    "prettier-plugin-solidity": "^1.3.1",
    "solhint": "^4.5.4",
    "solidity-coverage": "^0.8.12",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "blockchain",
    "notary",
    "erc721",
    "erc3643",
    "defi",
    "document-securities",
    "ai-validation",
    "chainlink",
    "solidity"
  ],
  "author": "AI Autonomous Notary Protocol",
  "license": "MIT",
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "undici": "^6.24.0"
  }
}
